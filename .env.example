# ===== SmartHotel Environment Configuration =====
# Copy to .env and fill in values. NEVER commit .env to source control.
#
# Generate a secret key:  python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change-me-to-a-random-value
DATABASE_PATH=hotel.db
FLASK_DEBUG=true
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Initial admin password (only used when seeding the database for the first time)
ADMIN_PASSWORD=admin123
